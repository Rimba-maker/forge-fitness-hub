---
const programLinks = ['Strength Training','HIIT & Conditioning','Yoga & Mind-Body','Combat Sport','Personal Training'];
const memberLinks  = ['Basic — 550K','Plus — 950K','Gold — 1.5JT','Elite — 2.5JT','Day Pass — 150K'];
const infoLinks    = ['Cabang & Lokasi','FAQ','Group Schedule','Personal Trainer','Free Trial'];
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <div class="footer__logo">
          <div class="footer__logo-icon" aria-hidden="true">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="square">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <span class="footer__brand-name">FORGE FITNESS HUB</span>
        </div>
        <p class="footer__tagline">"Built by those who refuse average."</p>
        <div class="footer__social">
          <a href="#" class="footer__social-link">Instagram</a>
          <a href="#" class="footer__social-link">TikTok</a>
          <a href="#" class="footer__social-link">YouTube</a>
        </div>
      </div>

      <div>
        <div class="footer__col-title">Program</div>
        <ul class="footer__links">
          {programLinks.map(l => <li><a href="#programs">{l}</a></li>)}
        </ul>
      </div>

      <div>
        <div class="footer__col-title">Membership</div>
        <ul class="footer__links">
          {memberLinks.map(l => <li><a href="#membership">{l}</a></li>)}
        </ul>
      </div>

      <div>
        <div class="footer__col-title">Informasi</div>
        <ul class="footer__links">
          {infoLinks.map((l, i) => {
            const hrefs = ['#locations','#faq','#schedule','#trainers','#booking'];
            return <li><a href={hrefs[i]}>{l}</a></li>;
          })}
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">© 2025 Forge Fitness Hub. Jakarta · Surabaya · Bandung.</p>
      <div class="footer__legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms & Conditions</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 64px 40px 24px;
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
  }
  .footer__inner { max-width: 1440px; margin: 0 auto; }
  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 64px;
    padding-bottom: 64px;
    border-bottom: 1px solid var(--color-hairline);
  }
  .footer__logo {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 12px;
  }
  .footer__logo-icon {
    width: 26px; height: 26px;
    background: var(--color-forge);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .footer__brand-name {
    font-family: var(--font-family-display);
    font-size: 17px; letter-spacing: 3px; color: #fff;
  }
  .footer__tagline {
    font-size: 13px; font-style: italic; font-weight: 300;
    color: var(--color-muted); margin-bottom: 20px;
  }
  .footer__social { display: flex; gap: 20px; }
  .footer__social-link {
    font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--color-muted);
    text-decoration: none; transition: color 0.2s;
  }
  .footer__social-link:hover { color: var(--color-forge); }
  .footer__col-title {
    font-size: 11px; font-weight: 700; letter-spacing: 1.8px;
    text-transform: uppercase; color: #fff; margin-bottom: 20px;
  }
  .footer__links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .footer__links a {
    font-size: 13px; font-weight: 300; color: var(--color-muted);
    text-decoration: none; transition: color 0.2s;
  }
  .footer__links a:hover { color: var(--color-body-str); }
  .footer__bottom {
    padding-top: 20px;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 12px;
  }
  .footer__copy { font-size: 12px; font-weight: 300; color: var(--color-muted); letter-spacing: 0.5px; }
  .footer__legal { display: flex; gap: 32px; }
  .footer__legal a { font-size: 12px; color: var(--color-muted); text-decoration: none; transition: color 0.2s; }
  .footer__legal a:hover { color: var(--color-body-text); }

  @media (max-width: 1024px) { .footer__top { grid-template-columns: 1fr 1fr; gap: 40px; } }
  @media (max-width: 640px) {
    .footer { padding: 48px 20px 20px; }
    .footer__top { grid-template-columns: 1fr; gap: 32px; padding-bottom: 32px; }
    .footer__bottom { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
