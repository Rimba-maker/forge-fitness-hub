---
// Forge Fitness Hub — index.astro
// Design system: BMW M adapted — dark canvas, rectangular precision, Forge orange accent
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forge Fitness Hub — Premium Gym & Fitness Center Jakarta, Surabaya</title>
  <meta name="description" content="Gym & fitness hub dengan 50+ group class/minggu, 30+ personal trainer bersertifikat, sauna, combat studio. 5 cabang. Coba gratis 7 hari." />

  <!-- Fonts: Bebas Neue (campaign display) + Inter (UI + body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;700&display=swap" rel="stylesheet" />

  <style is:global>
    /* ── FORGE FITNESS HUB — Design Tokens (BMW M adapted) ──────────── */
    :root {
      /* Canvas / Surfaces */
      --canvas:           #000000;
      --surface-card:     #1a1a1a;
      --surface-elevated: #262626;
      --surface-soft:     #0d0d0d;
      --hairline:         #3c3c3c;
      --hairline-strong:  #262626;

      /* Text */
      --on-dark:     #ffffff;
      --body:        #b0b0b0;
      --body-strong: #e0e0e0;
      --muted:       #7e7e7e;

      /* Brand — Forge Orange (fire / hot iron) */
      --forge:      #FF5500;
      --forge-dark: #CC3300;
      --forge-glow: rgba(255,85,0,0.12);

      /* Typography */
      --font-display: 'Bebas Neue', 'Impact', sans-serif;
      --font-body:    'Inter', -apple-system, BlinkMacSystemFont, sans-serif;

      /* Spacing (BMW M scale, base 4px) */
      --sp-xxs:     4px;
      --sp-xs:      8px;
      --sp-sm:      12px;
      --sp-md:      16px;
      --sp-lg:      24px;
      --sp-xl:      40px;
      --sp-xxl:     64px;
      --sp-section: 96px;

      /* Border radius — almost always 0 (BMW M rule) */
      --r-none: 0px;
      --r-full: 9999px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--canvas);
      color: var(--on-dark);
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }
    img { display: block; max-width: 100%; }

    /* ── UTILITIES ────────────────────────────────────────────────────── */
    .label-upper {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--forge);
      font-family: var(--font-body);
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(40px, 5.5vw, 72px);
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--on-dark);
      line-height: 0.95;
    }

    .section-body {
      font-size: 16px;
      font-weight: 300;
      color: var(--body);
      line-height: 1.75;
    }

    .forge-stripe {
      display: block;
      height: 3px;
      width: 40px;
      background: var(--forge);
      margin-bottom: var(--sp-lg);
    }

    /* ── BUTTONS ──────────────────────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-body);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: var(--r-none);
      padding: 0 var(--sp-xl);
      height: 48px;
      cursor: pointer;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      border: 1px solid transparent;
      white-space: nowrap;
    }
    .btn-primary {
      background: var(--forge);
      color: var(--on-dark);
      border-color: var(--forge);
    }
    .btn-primary:hover { background: var(--forge-dark); border-color: var(--forge-dark); }

    .btn-outline {
      background: transparent;
      color: var(--on-dark);
      border-color: var(--on-dark);
    }
    .btn-outline:hover { background: var(--on-dark); color: var(--canvas); }

    .btn-ghost {
      background: transparent;
      color: var(--body-strong);
      border-color: var(--hairline);
    }
    .btn-ghost:hover { border-color: var(--on-dark); color: var(--on-dark); }

    /* ── NAVBAR ───────────────────────────────────────────────────────── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      height: 64px;
      background: rgba(0,0,0,0.9);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--hairline);
    }
    .nav__inner {
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 var(--sp-xl);
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav__logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }
    .nav__logo-icon {
      width: 30px;
      height: 30px;
      background: var(--forge);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .nav__logo-text {
      font-family: var(--font-display);
      font-size: 20px;
      letter-spacing: 3px;
      color: var(--on-dark);
    }
    .nav__links {
      display: flex;
      align-items: center;
      gap: var(--sp-xl);
      list-style: none;
    }
    .nav__links a {
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.5px;
      color: var(--body);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav__links a:hover { color: var(--on-dark); }

    /* ── HERO ─────────────────────────────────────────────────────────── */
    .hero {
      position: relative;
      width: 100%;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      overflow: hidden;
    }
    .hero__bg {
      position: absolute;
      inset: 0;
      object-fit: cover;
      width: 100%;
      height: 100%;
    }
    .hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(0,0,0,0.97) 0%,
        rgba(0,0,0,0.55) 45%,
        rgba(0,0,0,0.15) 100%
      );
    }
    .hero__content {
      position: relative;
      z-index: 2;
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 var(--sp-xl) var(--sp-section);
      width: 100%;
    }
    .hero__headline {
      font-family: var(--font-display);
      font-size: clamp(80px, 14vw, 180px);
      line-height: 0.88;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--on-dark);
      margin: var(--sp-md) 0 var(--sp-xl);
    }
    .hero__headline .accent { color: var(--forge); }
    .hero__sub {
      font-size: 18px;
      font-weight: 300;
      color: var(--body-strong);
      max-width: 540px;
      line-height: 1.7;
      margin-bottom: var(--sp-xl);
    }
    .hero__ctas {
      display: flex;
      gap: var(--sp-md);
      flex-wrap: wrap;
      margin-bottom: var(--sp-xxl);
    }
    .hero__stats {
      display: grid;
      grid-template-columns: repeat(4, auto);
      justify-content: start;
      gap: var(--sp-xxl);
      padding-top: var(--sp-xl);
      border-top: 1px solid var(--hairline);
    }
    .stat__value {
      font-family: var(--font-display);
      font-size: 42px;
      letter-spacing: 1px;
      color: var(--on-dark);
      line-height: 1;
    }
    .stat__label {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 1.5px;
      color: var(--muted);
      margin-top: 6px;
      text-transform: uppercase;
    }

    /* ── FREE TRIAL ───────────────────────────────────────────────────── */
    .trial {
      background: var(--surface-soft);
      padding: var(--sp-section) var(--sp-xl);
      border-top: 3px solid var(--forge);
    }
    .trial__inner {
      max-width: 1440px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-xxl);
      align-items: center;
    }
    .trial__benefits {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--sp-md);
      margin: var(--sp-xl) 0;
    }
    .trial__benefit {
      display: flex;
      align-items: center;
      gap: var(--sp-md);
      font-size: 15px;
      font-weight: 400;
      color: var(--body-strong);
    }
    .trial__dot {
      width: 8px;
      height: 8px;
      background: var(--forge);
      flex-shrink: 0;
    }
    .trial__photo-wrap {
      position: relative;
    }
    .trial__photo {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
    }
    .trial__badge {
      position: absolute;
      bottom: var(--sp-lg);
      left: var(--sp-lg);
      background: var(--forge);
      padding: var(--sp-sm) var(--sp-lg);
    }
    .trial__badge-text {
      font-family: var(--font-display);
      font-size: 32px;
      color: var(--on-dark);
      letter-spacing: 2px;
      line-height: 1;
    }

    /* ── PROGRAMS ─────────────────────────────────────────────────────── */
    .programs {
      padding: var(--sp-section) var(--sp-xl);
      background: var(--canvas);
    }
    .programs__header {
      max-width: 1440px;
      margin: 0 auto var(--sp-xxl);
    }
    .programs__grid {
      max-width: 1440px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--hairline);
    }
    .program-card {
      position: relative;
      overflow: hidden;
      aspect-ratio: 4/3;
      background: var(--surface-card);
    }
    .program-card__photo {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .program-card:hover .program-card__photo { transform: scale(1.06); }
    .program-card__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.08) 60%);
    }
    .program-card__content {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: var(--sp-xl);
    }
    .program-card__title {
      font-family: var(--font-display);
      font-size: 34px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--on-dark);
      margin-bottom: var(--sp-xs);
      line-height: 1;
    }
    .program-card__items {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }
    .program-card__item {
      font-size: 13px;
      font-weight: 300;
      color: var(--body);
    }

    /* ── SCHEDULE ─────────────────────────────────────────────────────── */
    .schedule {
      padding: var(--sp-section) var(--sp-xl);
      background: var(--surface-soft);
      border-top: 1px solid var(--hairline);
    }
    .schedule__inner { max-width: 1440px; margin: 0 auto; }
    .schedule__header { margin-bottom: var(--sp-xxl); }
    .schedule__table-wrap { overflow-x: auto; }
    .schedule__table {
      width: 100%;
      border-collapse: collapse;
      min-width: 860px;
    }
    .schedule__table th {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: var(--muted);
      text-align: left;
      padding: var(--sp-md) var(--sp-lg);
      border-bottom: 1px solid var(--hairline);
    }
    .schedule__table th:first-child { color: var(--forge); }
    .schedule__table td {
      font-size: 13px;
      font-weight: 400;
      color: var(--body);
      padding: var(--sp-md) var(--sp-lg);
      border-bottom: 1px solid var(--hairline-strong);
    }
    .schedule__table td:first-child {
      font-weight: 700;
      color: var(--body-strong);
      letter-spacing: 0.5px;
    }
    .class-pill {
      display: inline-block;
      padding: 3px 9px;
      background: var(--surface-elevated);
      font-size: 12px;
      font-weight: 500;
      color: var(--body-strong);
    }
    .class-pill--hiit  { background: rgba(255,85,0,0.18); color: var(--forge); }
    .class-pill--yoga  { background: rgba(90,170,90,0.15); color: #7dbd7d; }
    .class-pill--combat{ background: rgba(190,70,70,0.18); color: #d98080; }
    .schedule__footer {
      display: flex;
      justify-content: flex-end;
      gap: var(--sp-md);
      margin-top: var(--sp-xl);
    }

    /* ── FACILITIES ───────────────────────────────────────────────────── */
    .facilities {
      padding: var(--sp-section) var(--sp-xl);
      background: var(--canvas);
    }
    .facilities__inner { max-width: 1440px; margin: 0 auto; }
    .facilities__header { margin-bottom: var(--sp-xxl); }
    .facilities__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--hairline);
    }
    .facility-card {
      background: var(--surface-card);
      overflow: hidden;
    }
    .facility-card__photo {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
    }
    .facility-card__body { padding: var(--sp-xl); }
    .facility-card__name {
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.3px;
      color: var(--on-dark);
      margin-bottom: var(--sp-xs);
    }
    .facility-card__desc {
      font-size: 13px;
      font-weight: 300;
      color: var(--body);
      line-height: 1.65;
    }
    .facility-card__tag {
      display: inline-block;
      margin-top: var(--sp-md);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: var(--muted);
    }
    .facility-card__tag--gold { color: #c8a02a; }

    .facility-card--hours {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: var(--sp-xs);
      background: var(--surface-elevated);
      padding: var(--sp-xxl) var(--sp-xl);
      text-align: center;
    }
    .facility-card--hours .h-value {
      font-family: var(--font-display);
      font-size: 56px;
      letter-spacing: 2px;
      color: var(--forge);
      line-height: 1;
    }
    .facility-card--hours .h-sep {
      font-family: var(--font-display);
      font-size: 28px;
      letter-spacing: 2px;
      color: var(--on-dark);
    }
    .facility-card--hours .h-label {
      margin-top: var(--sp-md);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* ── TRAINERS ─────────────────────────────────────────────────────── */
    .trainers {
      padding: var(--sp-section) var(--sp-xl);
      background: var(--surface-soft);
      border-top: 1px solid var(--hairline);
    }
    .trainers__inner { max-width: 1440px; margin: 0 auto; }
    .trainers__header { margin-bottom: var(--sp-xxl); }
    .trainers__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--hairline);
    }
    .trainer-card { background: var(--canvas); overflow: hidden; }
    .trainer-card__photo {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      filter: grayscale(25%);
      transition: filter 0.5s;
    }
    .trainer-card:hover .trainer-card__photo { filter: grayscale(0%); }
    .trainer-card__info {
      padding: var(--sp-lg) var(--sp-xl) var(--sp-xl);
      background: var(--surface-card);
    }
    .trainer-card__name {
      font-family: var(--font-display);
      font-size: 26px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--on-dark);
      margin-bottom: 3px;
    }
    .trainer-card__specialty {
      font-size: 12px;
      font-weight: 600;
      color: var(--forge);
      letter-spacing: 0.3px;
      margin-bottom: var(--sp-xs);
    }
    .trainer-card__cert {
      font-size: 12px;
      font-weight: 300;
      color: var(--muted);
    }
    .trainer-card__price {
      margin-top: var(--sp-md);
      font-size: 13px;
      font-weight: 600;
      color: var(--body-strong);
    }

    /* ── MEMBERSHIP ───────────────────────────────────────────────────── */
    .membership {
      padding: var(--sp-section) var(--sp-xl);
      background: var(--canvas);
    }
    .membership__inner { max-width: 1440px; margin: 0 auto; }
    .membership__header { margin-bottom: var(--sp-xxl); }
    .membership__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--hairline);
    }
    .plan-card {
      background: var(--surface-card);
      padding: var(--sp-xl);
      border-top: 3px solid var(--hairline);
      display: flex;
      flex-direction: column;
    }
    .plan-card--popular { border-top-color: var(--forge); }
    .plan-card__badge {
      align-self: flex-start;
      background: var(--forge);
      padding: 3px 10px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: var(--on-dark);
      margin-bottom: var(--sp-lg);
    }
    .plan-card__name {
      font-family: var(--font-display);
      font-size: 36px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--on-dark);
      margin-bottom: var(--sp-xs);
    }
    .plan-card__price {
      font-family: var(--font-display);
      font-size: 52px;
      letter-spacing: 1px;
      color: var(--on-dark);
      line-height: 1;
      margin-bottom: 3px;
    }
    .plan-card--popular .plan-card__price { color: var(--forge); }
    .plan-card__period {
      font-size: 12px;
      font-weight: 300;
      color: var(--muted);
      letter-spacing: 0.5px;
      margin-bottom: var(--sp-xl);
    }
    .plan-card__features {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--sp-sm);
      flex: 1;
      margin-bottom: var(--sp-xl);
    }
    .plan-card__feature {
      display: flex;
      align-items: flex-start;
      gap: var(--sp-sm);
      font-size: 14px;
      font-weight: 300;
      color: var(--body);
      line-height: 1.5;
    }
    .plan-card__feature::before {
      content: '';
      width: 5px;
      height: 5px;
      background: var(--forge);
      flex-shrink: 0;
      margin-top: 8px;
    }
    .plan-card__cta { width: 100%; justify-content: center; }
    .membership__note {
      margin-top: var(--sp-lg);
      padding: var(--sp-lg) var(--sp-xl);
      background: var(--surface-card);
      border-left: 3px solid var(--forge);
      display: flex;
      align-items: center;
      gap: var(--sp-xl);
    }
    .membership__note p {
      font-size: 14px;
      font-weight: 300;
      color: var(--body);
    }

    /* ── TRANSFORMATION ───────────────────────────────────────────────── */
    .transformations {
      padding: var(--sp-section) var(--sp-xl);
      background: var(--surface-soft);
      border-top: 1px solid var(--hairline);
    }
    .transformations__inner { max-width: 1440px; margin: 0 auto; }
    .transformations__header { margin-bottom: var(--sp-xxl); }
    .transformations__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--hairline);
    }
    .transform-card {
      background: var(--surface-card);
      padding: var(--sp-xxl);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-xl);
      align-items: start;
    }
    .transform-card__photos {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
    }
    .transform-card__photo {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
    }
    .transform-card__photo--before { filter: grayscale(70%); opacity: 0.65; }
    .transform-card__photo-label {
      text-align: center;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: var(--sp-xs) 0;
      color: var(--muted);
    }
    .transform-card__photo-label--after { color: var(--forge); }
    .transform-card__info { padding-top: var(--sp-xs); }
    .transform-card__name {
      font-family: var(--font-display);
      font-size: 30px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--on-dark);
      margin-bottom: 3px;
    }
    .transform-card__program {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--forge);
      margin-bottom: var(--sp-lg);
    }
    .transform-card__result {
      font-family: var(--font-display);
      font-size: 52px;
      letter-spacing: 1px;
      color: var(--on-dark);
      line-height: 1;
      margin-bottom: 2px;
    }
    .transform-card__result-label {
      font-size: 12px;
      font-weight: 300;
      color: var(--muted);
      margin-bottom: var(--sp-lg);
    }
    .transform-card__story {
      font-size: 14px;
      font-weight: 300;
      color: var(--body);
      line-height: 1.75;
    }
    .transform-card__duration {
      display: inline-block;
      margin-top: var(--sp-lg);
      padding: 3px 10px;
      background: var(--surface-elevated);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--body-strong);
    }

    /* ── LOCATIONS ────────────────────────────────────────────────────── */
    .locations {
      padding: var(--sp-section) var(--sp-xl);
      background: var(--canvas);
    }
    .locations__inner { max-width: 1440px; margin: 0 auto; }
    .locations__header { margin-bottom: var(--sp-xxl); }
    .locations__grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 1px;
      background: var(--hairline);
    }
    .location-card {
      background: var(--surface-card);
      padding: var(--sp-xl);
    }
    .location-card--flagship { background: var(--surface-elevated); }
    .location-card__flag {
      display: inline-block;
      padding: 2px 8px;
      background: var(--forge);
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--on-dark);
      margin-bottom: var(--sp-md);
    }
    .location-card__name {
      font-family: var(--font-display);
      font-size: 28px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--on-dark);
      line-height: 1;
      margin-bottom: var(--sp-xs);
    }
    .location-card__size {
      font-family: var(--font-display);
      font-size: 18px;
      letter-spacing: 1px;
      color: var(--forge);
      margin-bottom: var(--sp-lg);
    }
    .location-card__features {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--sp-xs);
    }
    .location-card__feature {
      font-size: 13px;
      font-weight: 300;
      color: var(--body);
      display: flex;
      align-items: center;
      gap: var(--sp-xs);
    }
    .location-card__feature::before {
      content: '';
      width: 3px;
      height: 3px;
      background: var(--hairline);
      flex-shrink: 0;
    }
    .location-card__hours {
      margin-top: var(--sp-lg);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* ── FAQ ──────────────────────────────────────────────────────────── */
    .faq {
      padding: var(--sp-section) var(--sp-xl);
      background: var(--surface-soft);
      border-top: 1px solid var(--hairline);
    }
    .faq__inner {
      max-width: 1440px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: var(--sp-xxl);
    }
    .faq__left { position: sticky; top: 80px; align-self: start; }
    .faq__list { display: flex; flex-direction: column; }
    .faq__item { border-bottom: 1px solid var(--hairline); }
    .faq__question {
      width: 100%;
      background: none;
      border: none;
      padding: var(--sp-xl) 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--sp-xl);
      cursor: pointer;
      text-align: left;
    }
    .faq__question-text {
      font-size: 16px;
      font-weight: 500;
      color: var(--on-dark);
      line-height: 1.5;
    }
    .faq__icon {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      position: relative;
    }
    .faq__icon::before, .faq__icon::after {
      content: '';
      position: absolute;
      background: var(--on-dark);
      transition: transform 0.3s;
    }
    .faq__icon::before { width: 18px; height: 1px; top: 50%; left: 0; transform: translateY(-50%); }
    .faq__icon::after  { width: 1px; height: 18px; left: 50%; top: 0; transform: translateX(-50%); }
    .faq__item.open .faq__icon::after { transform: translateX(-50%) scaleY(0); }
    .faq__answer {
      font-size: 15px;
      font-weight: 300;
      color: var(--body);
      line-height: 1.75;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease, padding 0.3s;
    }
    .faq__item.open .faq__answer {
      max-height: 280px;
      padding-bottom: var(--sp-xl);
    }

    /* ── BOOKING BAND ─────────────────────────────────────────────────── */
    .booking-band {
      position: relative;
      padding: var(--sp-section) var(--sp-xl);
      overflow: hidden;
    }
    .booking-band__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .booking-band__overlay {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.82);
    }
    .booking-band__content {
      position: relative;
      z-index: 2;
      max-width: 1440px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-xxl);
      align-items: center;
    }
    .booking-band__headline {
      font-family: var(--font-display);
      font-size: clamp(52px, 7vw, 88px);
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--on-dark);
      line-height: 0.92;
      margin: var(--sp-md) 0 var(--sp-lg);
    }
    .booking-band__headline .accent { color: var(--forge); }
    .booking-band__sub {
      font-size: 16px;
      font-weight: 300;
      color: var(--body);
      line-height: 1.75;
    }
    .booking-form {
      background: var(--surface-card);
      padding: var(--sp-xxl);
      border-top: 3px solid var(--forge);
    }
    .form-group { margin-bottom: var(--sp-md); }
    .form-label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .form-input, .form-select {
      width: 100%;
      background: var(--surface-elevated);
      border: 1px solid var(--hairline);
      color: var(--on-dark);
      font-family: var(--font-body);
      font-size: 15px;
      font-weight: 300;
      padding: 0 var(--sp-md);
      height: 48px;
      border-radius: 0;
      appearance: none;
      -webkit-appearance: none;
      transition: border-color 0.2s;
    }
    .form-input::placeholder { color: var(--muted); }
    .form-input:focus, .form-select:focus {
      outline: none;
      border-color: var(--forge);
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-md);
    }
    .form-submit { width: 100%; justify-content: center; margin-top: var(--sp-xs); }

    /* ── FOOTER ───────────────────────────────────────────────────────── */
    .footer {
      padding: var(--sp-xxl) var(--sp-xl) var(--sp-lg);
      background: var(--canvas);
      border-top: 1px solid var(--hairline);
    }
    .footer__inner { max-width: 1440px; margin: 0 auto; }
    .footer__top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: var(--sp-xxl);
      padding-bottom: var(--sp-xxl);
      border-bottom: 1px solid var(--hairline);
    }
    .footer__logo {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: var(--sp-md);
    }
    .footer__brand-name {
      font-family: var(--font-display);
      font-size: 18px;
      letter-spacing: 3px;
      color: var(--on-dark);
    }
    .footer__tagline {
      font-size: 13px;
      font-style: italic;
      font-weight: 300;
      color: var(--muted);
      margin-bottom: var(--sp-lg);
    }
    .footer__social {
      display: flex;
      gap: var(--sp-lg);
    }
    .footer__social-link {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer__social-link:hover { color: var(--forge); }
    .footer__col-title {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: var(--on-dark);
      margin-bottom: var(--sp-lg);
    }
    .footer__links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--sp-sm);
    }
    .footer__links a {
      font-size: 13px;
      font-weight: 300;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer__links a:hover { color: var(--body-strong); }
    .footer__bottom {
      padding-top: var(--sp-lg);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: var(--sp-md);
    }
    .footer__copy {
      font-size: 12px;
      font-weight: 300;
      color: var(--muted);
      letter-spacing: 0.5px;
    }
    .footer__legal {
      display: flex;
      gap: var(--sp-xl);
    }
    .footer__legal a {
      font-size: 12px;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer__legal a:hover { color: var(--body); }

    /* ── RESPONSIVE ───────────────────────────────────────────────────── */
    @media (max-width: 1200px) {
      .facilities__grid { grid-template-columns: repeat(2, 1fr); }
      .locations__grid  { grid-template-columns: repeat(3, 1fr); }
      .trainers__grid   { grid-template-columns: repeat(3, 1fr); }
      .footer__top      { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 1024px) {
      .programs__grid     { grid-template-columns: repeat(2, 1fr); }
      .membership__grid   { grid-template-columns: repeat(2, 1fr); }
      .transformations__grid { grid-template-columns: 1fr; }
      .booking-band__content { grid-template-columns: 1fr; }
      .faq__inner         { grid-template-columns: 1fr; }
      .faq__left          { position: static; }
    }
    @media (max-width: 768px) {
      :root {
        --sp-section: 60px;
        --sp-xxl: 40px;
        --sp-xl: 24px;
      }
      .nav__links         { display: none; }
      .hero__headline     { font-size: 72px; }
      .hero__stats        { grid-template-columns: repeat(2, 1fr); gap: var(--sp-xl); }
      .trial__inner       { grid-template-columns: 1fr; }
      .programs__grid     { grid-template-columns: 1fr; }
      .facilities__grid   { grid-template-columns: 1fr; }
      .trainers__grid     { grid-template-columns: repeat(2, 1fr); }
      .membership__grid   { grid-template-columns: 1fr; }
      .locations__grid    { grid-template-columns: 1fr; }
      .transform-card     { grid-template-columns: 1fr; }
      .form-row           { grid-template-columns: 1fr; }
      .footer__top        { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .hero__headline     { font-size: 56px; }
      .hero__stats        { grid-template-columns: 1fr 1fr; }
      .trainers__grid     { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

